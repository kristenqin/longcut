# Copy this file to .env.local and replace placeholder values.

# Text generation provider
AI_PROVIDER=deepseek
NEXT_PUBLIC_AI_PROVIDER=deepseek
AI_DEFAULT_MODEL=deepseek-v4-flash
NEXT_PUBLIC_AI_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# Optional override for self-hosted or alternate DeepSeek gateways.
DEEPSEEK_API_BASE_URL=https://api.deepseek.com

# Optional MiniMax provider
# MINIMAX_API_KEY=your_minimax_api_key_here
# MINIMAX_API_BASE_URL=

# Optional fallback text providers
# XAI_API_KEY=your_xai_api_key_here

# Image generation
# Required if you want app/api/generate-image/route.ts to work.
GEMINI_API_KEY=your_gemini_api_key_here

# Core app configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
CSRF_SALT=generate_a_long_random_string_here
AI_SETTINGS_ENCRYPTION_KEY=generate_a_long_random_string_here

# Optional features
NEXT_PUBLIC_ENABLE_TRANSLATION_SELECTOR=false
NEXT_PUBLIC_ENABLE_HIGHLIGHT_REELS=false
NEXT_PUBLIC_ENABLE_CHAT_PLUGIN=false
NEXT_PUBLIC_ENABLE_NOTES_PLUGIN=false
NEXT_PUBLIC_ENABLE_TRANSCRIPT_EXPORT=false
NEXT_PUBLIC_ENABLE_QUICK_PREVIEW=false
NEXT_PUBLIC_ENABLE_TAKEAWAYS_PLUGIN=false
YOUTUBE_PROXY_URL=
YOUTUBE_API_KEY=
BILIBILI_COOKIE=
UNLIMITED_VIDEO_USERS=

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRO_PRICE_ID=price_your_pro_price_id_here
STRIPE_TOPUP_PRICE_ID=price_your_topup_price_id_here
